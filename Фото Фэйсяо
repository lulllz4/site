<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>КГБ КПМ // ДОСЬЕ ТИНЪЮНЬ // ГРИФ "ОСОБОЙ ВАЖНОСТИ"</title>
<link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Press+Start+2P&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  /* -------------------- БАЗОВЫЕ СТИЛИ -------------------- */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: #0a0c10;
    font-family: 'Special Elite', 'Share Tech Mono', 'Courier New', monospace;
    min-height: 100vh;
    color: #b8c6db;
    padding: 0 20px;
    position: relative;
  }

  /* -------------------- ЭФФЕКТЫ ЭЛТ-МОНИТОРА -------------------- */
  .scan-line {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0) 100%);
    animation: scan 8s linear infinite;
    pointer-events: none;
    z-index: 9997;
  }

  @keyframes scan {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }

  .crt::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(0deg, rgba(0,0,0,0.08) 0px, rgba(0,0,0,0.08) 1px, transparent 1px, transparent 2px);
    pointer-events: none;
    z-index: 9998;
  }

  .crt::after {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(ellipse at center, rgba(0,0,0,0) 50%, rgba(0,0,0,0.4) 100%);
    pointer-events: none;
    z-index: 9998;
  }

  /* -------------------- МЕРЦАНИЕ КАРТИНКИ (ЭФФЕКТ СТАРОГО МОНИТОРА) -------------------- */
  @keyframes flickerImage {
    0% { opacity: 0.92; filter: grayscale(15%) contrast(1.1) brightness(1); }
    10% { opacity: 0.88; filter: grayscale(20%) contrast(1.15) brightness(0.98); }
    20% { opacity: 0.95; filter: grayscale(10%) contrast(1.05) brightness(1.02); }
    30% { opacity: 0.85; filter: grayscale(25%) contrast(1.2) brightness(0.95); }
    40% { opacity: 0.93; filter: grayscale(12%) contrast(1.08) brightness(1); }
    50% { opacity: 0.89; filter: grayscale(18%) contrast(1.12) brightness(0.97); }
    60% { opacity: 0.96; filter: grayscale(8%) contrast(1.02) brightness(1.03); }
    70% { opacity: 0.87; filter: grayscale(22%) contrast(1.18) brightness(0.96); }
    80% { opacity: 0.94; filter: grayscale(14%) contrast(1.1) brightness(0.99); }
    90% { opacity: 0.91; filter: grayscale(16%) contrast(1.14) brightness(0.98); }
    100% { opacity: 0.92; filter: grayscale(15%) contrast(1.1) brightness(1); }
  }

  @keyframes horizontalJitter {
    0% { transform: translateX(0px); }
    25% { transform: translateX(0.5px); }
    75% { transform: translateX(-0.3px); }
    100% { transform: translateX(0px); }
  }

  .photo-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    animation: 
      flickerImage 0.15s steps(2, jump-end) infinite,
      horizontalJitter 0.08s linear infinite;
    display: block;
  }

  /* -------------------- МЕРЦАНИЕ ТАБЛИЦ И ТЕКСТА (ЭФФЕКТ НЕСТАБИЛЬНОГО СИГНАЛА) -------------------- */
  @keyframes textFlicker {
    0% { text-shadow: 0 0 0px rgba(200,0,0,0); }
    50% { text-shadow: 0 0 1px rgba(200,0,0,0.3); }
    100% { text-shadow: 0 0 0px rgba(200,0,0,0); }
  }

  @keyframes cardFlicker {
    0% { border-color: #2a1a1a; background: rgba(10, 12, 16, 0.85); }
    50% { border-color: #3a1a1a; background: rgba(10, 12, 16, 0.88); }
    100% { border-color: #2a1a1a; background: rgba(10, 12, 16, 0.85); }
  }

  .card {
    background: rgba(10, 12, 16, 0.85);
    backdrop-filter: blur(1px);
    border: 1px solid #2a1a1a;
    transition: all 0.2s;
    box-shadow: 4px 4px 0px rgba(0,0,0,0.4);
    animation: cardFlicker 0.3s ease-in-out infinite;
  }

  .card-body, .info-value, .timeline-card .desc, .dialogue-line {
    animation: textFlicker 0.2s step-end infinite;
  }

  /* Более сильное мерцание для важных элементов */
  @keyframes strongFlicker {
    0% { opacity: 0.95; text-shadow: 0 0 0px #8b0000; }
    50% { opacity: 0.85; text-shadow: 0 0 2px #8b0000; }
    100% { opacity: 0.95; text-shadow: 0 0 0px #8b0000; }
  }

  .blink-red, .status, .warning-footer, .tag, .photo-stamp {
    animation: strongFlicker 0.15s step-end infinite;
  }

  /* -------------------- ОСТАЛЬНЫЕ АНИМАЦИИ -------------------- */
  @keyframes blinkRed {
    0%, 100% { color: #cc1a1a; }
    50% { color: #ff4444; }
  }

  @keyframes ledBlink {
    0%, 100% { background: #cc1a1a; box-shadow: 0 0 1px #cc1a1a; }
    50% { background: #ff4444; box-shadow: 0 0 4px #ff4444; }
  }

  @keyframes pulseBorder {
    0%, 100% { border-color: rgba(139,0,0,0.4); box-shadow: 0 0 2px rgba(139,0,0,0.2); }
    50% { border-color: rgba(200,0,0,0.9); box-shadow: 0 0 6px rgba(200,0,0,0.4); }
  }

  .led-active {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: #cc1a1a;
    border-radius: 50%;
    margin-right: 6px;
    animation: ledBlink 1.5s step-end infinite;
    box-shadow: 0 0 2px red;
  }

  /* -------------------- ОСНОВНЫЕ ЭЛЕМЕНТЫ ДИЗАЙНА -------------------- */
  .vertical-stripe {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: 35px;
    background: linear-gradient(180deg, #1a0000 0%, #8b0000 30%, #1a0000 70%, #0a0000 100%);
    z-index: 1000;
    box-shadow: 2px 0 12px rgba(0,0,0,0.8);
  }

  .vertical-stripe .stripe-text {
    position: absolute;
    bottom: 50px;
    left: 50%;
    transform: translateX(-50%) rotate(-90deg);
    white-space: nowrap;
    font-size: 9px;
    letter-spacing: 3px;
    color: #6a1a1a;
    font-weight: bold;
    font-family: 'Press Start 2P', monospace;
  }

  .wrapper {
    max-width: 1300px;
    margin: 0 auto;
    position: relative;
    padding-left: 45px;
    z-index: 1;
  }

  /* -------------------- ШАПКА -------------------- */
  .secret-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 20px 0;
    border-bottom: 2px solid #8b0000;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 15px;
  }

  .stamp-left .security {
    font-size: 9px;
    letter-spacing: 3px;
    color: #cc1a1a;
    font-family: 'Press Start 2P', monospace;
    background: rgba(139,0,0,0.15);
    padding: 4px 8px;
    display: inline-block;
    border-left: 2px solid #cc1a1a;
  }

  .stamp-left .number {
    font-size: 9px;
    margin-top: 8px;
    color: #7a6a5a;
    font-family: monospace;
  }

  .logo-center {
    text-align: center;
  }

  .logo-center .emblem {
    font-size: 32px;
    color: #8b0000;
    text-shadow: 1px 1px 0px #2a0a0a;
    filter: drop-shadow(0 0 2px rgba(200,0,0,0.5));
  }

  .logo-center .title {
    font-family: 'Press Start 2P', monospace;
    font-size: 14px;
    letter-spacing: 2px;
    color: #c8a88a;
    margin-top: 6px;
  }

  .logo-center .sub {
    font-size: 7px;
    letter-spacing: 2px;
    color: #5a4a3a;
  }

  .stamp-right .status {
    font-size: 9px;
    color: #cc1a1a;
    border: 1px solid #8b0000;
    padding: 3px 12px;
    display: inline-block;
    background: rgba(139,0,0,0.2);
  }

  .stamp-right .date {
    font-size: 8px;
    margin-top: 8px;
    color: #6a5a4a;
  }

  /* -------------------- НАВИГАЦИЯ -------------------- */
  .side-nav {
    position: fixed;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 10px;
    z-index: 100;
  }

  .nav-btn {
    width: 45px;
    height: 45px;
    background: #0f1115;
    border: 1px solid #8b0000;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 18px;
    color: #8b0000;
    box-shadow: 0 0 5px rgba(139,0,0,0.2);
  }

  .nav-btn:hover, .nav-btn.active {
    background: #8b0000;
    color: #0a0c10;
    box-shadow: 0 0 12px rgba(200,0,0,0.6);
    border-color: #cc1a1a;
  }

  /* -------------------- КАРТОЧКИ -------------------- */
  .card-header {
    padding: 10px 14px;
    background: rgba(20, 10, 10, 0.6);
    border-left: 4px solid #8b0000;
    border-bottom: 1px solid #2a1a1a;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    letter-spacing: 1px;
    color: #c8a88a;
  }

  .card-header .header-icon {
    font-size: 14px;
    color: #8b0000;
  }

  .card-body {
    padding: 14px;
    font-size: 12px;
    line-height: 1.6;
    color: #b8c6db;
  }

  /* -------------------- ФОТО -------------------- */
  .photo-big {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .photo-container {
    background: #050608;
    border: 2px solid #2a1a1a;
    position: relative;
    aspect-ratio: 3/4;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 0 20px rgba(0,0,0,0.8);
    overflow: hidden;
    animation: pulseBorder 3s ease-in-out infinite;
  }

  .photo-stamp {
    position: absolute;
    bottom: 8px;
    right: 8px;
    font-size: 7px;
    color: #8b0000;
    border: 1px solid #8b0000;
    padding: 2px 5px;
    transform: rotate(-5deg);
    background: rgba(0,0,0,0.8);
    z-index: 2;
    font-family: monospace;
  }

  /* -------------------- ТАБЛИЦЫ И ДАННЫЕ -------------------- */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .info-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 8px;
    padding: 5px 0;
    border-bottom: 1px dotted #2a1a1a;
  }

  .info-label {
    width: 110px;
    font-size: 9px;
    letter-spacing: 1px;
    color: #8b0000;
    text-transform: uppercase;
  }

  .info-value {
    flex: 1;
    font-size: 12px;
    color: #c8bcac;
    font-family: monospace;
  }

  /* -------------------- ПОЛОСЫ УРОВНЕЙ -------------------- */
  .stat-item {
    margin-bottom: 14px;
  }

  .stat-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 5px;
  }

  .stat-name {
    font-size: 9px;
    letter-spacing: 1px;
    color: #7a6a5a;
  }

  .stat-value {
    font-size: 9px;
    color: #cc1a1a;
  }

  .stat-bar-container {
    height: 8px;
    background: #1a1010;
    border: 1px solid #3a2a2a;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.5);
  }

  .stat-fill {
    height: 100%;
    background: repeating-linear-gradient(90deg, #8b0000 0px, #8b0000 4px, #cc1a1a 4px, #cc1a1a 8px);
  }

  /* -------------------- ТАЙМЛАЙН -------------------- */
  .horizontal-timeline {
    display: flex;
    overflow-x: auto;
    gap: 15px;
    padding: 8px 0;
  }

  .timeline-card {
    min-width: 240px;
    background: #0a0c10;
    border-left: 3px solid #8b0000;
    padding: 10px 12px;
    box-shadow: 2px 2px 0px rgba(0,0,0,0.3);
  }

  .timeline-card .date {
    font-size: 9px;
    color: #8b0000;
    letter-spacing: 1.5px;
  }

  .timeline-card .title {
    font-size: 12px;
    font-weight: bold;
    margin: 5px 0;
    color: #c8a88a;
  }

  .timeline-card .desc {
    font-size: 10px;
    color: #8a7a6a;
  }

  /* -------------------- СТРАНИЦЫ -------------------- */
  .page {
    display: none;
  }

  .page.active-page {
    display: block;
  }

  /* -------------------- ДИАЛОГИ И БЛОКИ -------------------- */
  .dialogue-block {
    background: #0a0c10;
    border: 1px solid #2a1a1a;
    padding: 14px;
    margin: 12px 0;
  }

  .dialogue-header {
    font-size: 8px;
    color: #8b0000;
    letter-spacing: 2px;
    margin-bottom: 8px;
    border-bottom: 1px dashed #3a2a2a;
    padding-bottom: 4px;
  }

  .dialogue-line {
    padding: 5px 0;
    font-size: 11px;
    font-family: monospace;
  }

  .dialogue-line .speaker {
    color: #cc1a1a;
    font-weight: bold;
  }

  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 15px 0;
  }

  .tag {
    background: rgba(139,0,0,0.1);
    border: 1px solid #8b0000;
    padding: 3px 10px;
    font-size: 8px;
    letter-spacing: 1px;
    color: #cc1a1a;
    font-family: monospace;
  }

  .redacted {
    background: #1a1010;
    color: #1a1010;
    padding: 0 6px;
    display: inline-block;
    letter-spacing: 2px;
    user-select: none;
  }

  .warning-footer {
    margin: 20px 0;
    padding: 10px;
    text-align: center;
    background: linear-gradient(90deg, transparent, rgba(139,0,0,0.15), transparent);
    font-size: 8px;
    letter-spacing: 3px;
    color: #cc1a1a;
    border-top: 1px solid #2a1a1a;
    border-bottom: 1px solid #2a1a1a;
  }

  .footer {
    padding: 20px 0;
    display: flex;
    justify-content: space-between;
    font-size: 7px;
    color: #5a4a3a;
    letter-spacing: 1px;
    border-top: 1px solid #1a1010;
    margin-top: 20px;
  }

  @media (max-width: 900px) {
    .content-grid, .photo-big { grid-template-columns: 1fr; }
    .side-nav {
      position: fixed;
      bottom: 15px;
      top: auto;
      right: 15px;
      flex-direction: row;
      transform: none;
      background: rgba(10,12,16,0.9);
      padding: 5px;
      border-radius: 4px;
      border: 1px solid #8b0000;
    }
    .nav-btn { width: 35px; height: 35px; font-size: 14px; }
    .wrapper { padding-left: 20px; padding-bottom: 70px; }
    .vertical-stripe { width: 20px; }
  }
</style>
</head>
<body class="crt">

<div class="scan-line"></div>
<div class="vertical-stripe"><div class="stripe-text">КГБ КПМ // КРАСНАЯ ЛИНИЯ</div></div>

<div class="wrapper">

  <!-- ШАПКА С ИНДИКАТОРАМИ -->
  <div class="secret-header">
    <div class="stamp-left">
      <div class="security blink-red">СОВЕРШЕННО СЕКРЕТНО</div>
      <div class="number">ФОРМА КГБ-7А // ДОС-КЛ-2033-089</div>
    </div>
    <div class="logo-center">
      <div class="emblem">★</div>
      <div class="title">КГБ КРАСНОЙ ЛИНИИ</div>
